# Copy this file to .env and fill in your keys.

# FREE — get at https://aistudio.google.com/apikey  (Google account, no card needed)
GEMINI_API_KEY=

# FREE — get at https://www.pexels.com/api/  (sign up, instant key)
PEXELS_API_KEY=

# OPTIONAL, FREE — a YouTube Data API key (same Cloud project as the upload setup).
# Only used as a fallback for public view counts when the Analytics API returns
# nothing yet (its data lags 24-48h behind an upload). Safe to leave blank.
YOUTUBE_API_KEY=
